# ============================================================
# AI Model-as-a-Service (MaaS) Platform — Environment Config
# ============================================================
# Copy this to .env and fill in your values.

# --- Application ---
APP_NAME=maas-platform
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1

# --- PostgreSQL ---
POSTGRES_USER=maas_user
POSTGRES_PASSWORD=maas_secret_password
POSTGRES_DB=maas_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://maas_user:maas_secret_password@postgres:5432/maas_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# --- Model Storage ---
MODEL_STORAGE_PATH=/app/model_storage
MAX_MODEL_SIZE_MB=500
SUPPORTED_MODEL_FORMATS=pkl,onnx,pt,joblib

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# --- Caching ---
CACHE_TTL_SECONDS=300
CACHE_ENABLED=true

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Azure (Production) ---
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_CONTAINER_NAME=models
# AZURE_KEY_VAULT_URL=
